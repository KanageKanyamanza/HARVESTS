# Configuration de production pour HARVESTS
# Copiez ce fichier vers .env et remplissez les valeurs

# Environnement
NODE_ENV=production
PORT=8000

# Base de données MongoDB (Production)
# Option 1: Avec mot de passe (recommandé)
DATABASE=mongodb+srv://harvests:<PASSWORD>@cluster.mongodb.net/harvests?retryWrites=true&w=majority
DATABASE_PASSWORD=votre_mot_de_passe_mongodb

# Option 2: URL complète (alternative)
# DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/harvests?retryWrites=true&w=majority

# JWT
JWT_SECRET=votre_jwt_secret_tres_long_et_securise_en_production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=votre_email@gmail.com
EMAIL_PASSWORD=votre_mot_de_passe_application
EMAIL_FROM=HARVESTS <noreply@harvests.sn>

# EmailJS (FALLBACK - Solution de secours)
# EmailJS est utilisé automatiquement si Nodemailer échoue
EMAILJS_SERVICE_ID=votre_emailjs_service_id
EMAILJS_TEMPLATE_ID=votre_emailjs_template_id
EMAILJS_PUBLIC_KEY=votre_emailjs_public_key

# Cloudinary (Stockage d'images)
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# Stripe (Paiements)
STRIPE_SECRET_KEY=sk_live_votre_cle_secrete_stripe
STRIPE_WEBHOOK_SECRET=whsec_votre_webhook_secret

# PayPal (Paiements)
PAYPAL_CLIENT_ID=votre_paypal_client_id
PAYPAL_CLIENT_SECRET=votre_paypal_client_secret
PAYPAL_ENV=live
PAYPAL_DEFAULT_CURRENCY=EUR
PAYPAL_SUPPORTED_CURRENCIES=EUR,USD
PAYPAL_RETURN_URL=https://votre-frontend/payments/paypal/success
PAYPAL_CANCEL_URL=https://votre-frontend/payments/paypal/cancel
PAYPAL_WEBHOOK_ID=votre_paypal_webhook_id
PAYPAL_FEE_PERCENT=3.4
PAYPAL_FIXED_FEE=0.30
PAYPAL_EXCHANGE_RATES={"XAF->EUR":0.0016}
PAYPAL_DEFAULT_EXCHANGE_RATE=0.0016

# Frais de livraison (ajustez selon vos transporteurs)
DELIVERY_FEE_PICKUP_LOCAL=0
DELIVERY_FEE_STANDARD_LOCAL=2000
DELIVERY_FEE_EXPRESS_LOCAL=5000
DELIVERY_FEE_SAME_DAY_LOCAL=7000
DELIVERY_FEE_SCHEDULED_LOCAL=3000
DELIVERY_FEE_INTERCITY_BASE=4000
DELIVERY_FEE_PER_KM=0
DELIVERY_FEE_INTERNATIONAL_BASE=8000
DELIVERY_FEE_INTERCITY_STANDARD=4000
DELIVERY_FEE_INTERCITY_EXPRESS=6000
DELIVERY_FEE_INTERCITY_SAME_DAY=8000
DELIVERY_FEE_INTERCITY_SCHEDULED=5000
DELIVERY_FEE_INTERNATIONAL_STANDARD=8000
DELIVERY_FEE_INTERNATIONAL_EXPRESS=10000
DELIVERY_FEE_INTERNATIONAL_SAME_DAY=12000
DELIVERY_FEE_INTERNATIONAL_SCHEDULED=9000

# Firebase (Notifications push)
FIREBASE_PROJECT_ID=votre_project_id
FIREBASE_PRIVATE_KEY_ID=votre_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nvotre_private_key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=votre_client_email
FIREBASE_CLIENT_ID=votre_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Configuration Admin (Premier super-admin)
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Harvests
ADMIN_EMAIL=admin@harvests.sn
ADMIN_PASSWORD=Admin@Harvests2025!

# Sécurité
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
FRONTEND_URL=https://votre-frontend.vercel.app
ADMIN_FRONTEND_URL=https://votre-admin.vercel.app

# Logs
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=20m
LOG_FILE_MAX_FILES=14d
