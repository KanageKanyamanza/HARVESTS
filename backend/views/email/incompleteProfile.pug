doctype html
html(lang='fr')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= subject
    style.
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.6;
        color: #2d3748;
        background-color: #f7fafc;
        margin: 0;
        padding: 20px;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        overflow: hidden;
      }
      .header {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        padding: 40px 30px;
        text-align: center;
        color: white;
        border-radius: 12px 12px 0 0;
      }
      .logo {
        width: 120px;
        height: 120px;
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        padding: 10px;
      }
      .logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
      .title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 8px;
        letter-spacing: -0.025em;
      }
      .subtitle {
        font-size: 16px;
        opacity: 0.9;
        font-weight: 400;
      }
      .content {
        padding: 40px 30px;
      }
      .greeting {
        font-size: 18px;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 20px;
      }
      .message {
        font-size: 16px;
        color: #4a5568;
        margin-bottom: 24px;
        line-height: 1.7;
      }
      .cta-container {
        text-align: center;
        margin: 32px 0;
      }
      .cta-button {
        display: inline-block;
        background-color: #f59e0b;
        color: white;
        padding: 16px 32px;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 16px;
        box-shadow: 0 4px 6px -1px rgba(245, 158, 11, 0.3);
        transition: all 0.2s ease;
      }
      .cta-button:hover {
        background-color: #d97706;
        transform: translateY(-1px);
        box-shadow: 0 6px 8px -1px rgba(245, 158, 11, 0.4);
      }
      .features {
        background-color: #fffbeb;
        border-radius: 8px;
        padding: 16px;
        margin: 32px 0;
        border-left: 4px solid #f59e0b;
      }
      .features h3 {
        color: #92400e;
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 16px;
        text-align: center;
      }
      .features ul {
        list-style: none;
        padding: 0;
      }
      .features li {
        color: #78350f;
        font-size: 15px;
        margin-bottom: 12px;
        padding-left: 24px;
        position: relative;
      }
      .features li:before {
        content: '★';
        position: absolute;
        left: 0;
        color: #f59e0b;
        font-weight: bold;
        font-size: 16px;
      }
      .footer {
        background-color: #1f2937;
        color: #ffffff;
        padding: 30px;
        text-align: center;
        font-size: 14px;
        line-height: 1.6;
        border-radius: 0 0 12px 12px;
      }
      .footer-brand {
        color: #ffffff;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .footer-contact {
        margin: 12px 0;
      }
      .footer-contact a {
        color: #f59e0b;
        text-decoration: none;
      }
      .footer-contact a:hover {
        text-decoration: underline;
      }
      @media (max-width: 600px) {
        .email-container {
          margin: 0;
          border-radius: 0;
        }
        .header, .footer {
            border-radius: 0;
        }
        .header, .content, .footer {
          padding: 20px;
        }
        .title {
          font-size: 24px;
        }
        .logo {
          width: 100px;
          height: 100px;
          padding: 8px;
        }
      }
  body
    .email-container
      .header
        .logo
          img(src=logoUrl, alt='Harvests Logo', style='width: 100%; height: 100%; object-fit: contain;')
        .title Complétez votre profil
        .subtitle Optimisez votre visibilité sur Harvests
      
      .content
        .greeting Bonjour #{firstName},
        
        .message
          p Nous avons remarqué que votre profil sur Harvests est incomplet. Pour tirer le meilleur parti de notre plateforme et inspirer confiance à vos futurs partenaires, nous vous recommandons de compléter les informations manquantes.
        
        .features
          h3 Pourquoi avoir un profil complet ?
          ul
            li 📈 Meilleure visibilité dans les résultats de recherche
            li 🛡️ Confiance accrue auprès des autres utilisateurs
            li ✨ Accès à des fonctionnalités exclusives
            li 🚀 Plus d'opportunités d'affaires
        
        if missingFields && missingFields.length > 0
          .features
            h3(style="color: #c2410c; margin-bottom: 12px;") Ce qu'il manque à votre profil :
            ul
              each field in missingFields
                li(style="color: #9a3412;")= field

        .message
          p Cela ne prend que quelques minutes et peut faire toute la différence pour votre activité.
        
        .cta-container
          a.cta-button(href=url) Compléter mon profil maintenant
        
        .message
          p Si vous avez besoin d'aide, n'hésitez pas à nous contacter.
      
      .footer
        .footer-brand 🌱 Harvests
        .footer-contact
          | Plateforme agricole africaine - Connectons l'Afrique à travers l'agriculture
        .footer-contact
          | Questions ? Contactez-nous :
        .footer-contact
          | 📞 Sénégal : 
          a(href='tel:+221771970713') +221 771970713
        .footer-contact
          | 📧 Email : 
          a(href='mailto:contact@harvests.site') contact@harvests.site
        .footer-contact
          | © #{new Date().getFullYear()} Harvests. Tous droits réservés. | Dakar, Sénégal
