# Configuration de l'environnement
NODE_ENV=development
PORT=8000
API_VERSION=1.0.0

# Configuration de la base de données MongoDB
DATABASE=mongodb+srv://username:<PASSWORD>@cluster0.mongodb.net/harvests?retryWrites=true&w=majority
DATABASE_PASSWORD=your_mongodb_password
DATABASE_LOCAL=mongodb://localhost:27017/harvests

# Configuration JWT
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# Configuration Email (par ordre de priorité)
# Le système utilise automatiquement la première option configurée

# 🥇 Option 1: SendGrid (RECOMMANDÉ pour Render - 100 emails/jour GRATUIT)
# Créez un compte sur https://sendgrid.com et créez une API Key
SENDGRID_API_KEY=SG.votre-cle-api-sendgrid

# 🥈 Option 2: Mailgun (EXCELLENT - 5000 emails/mois GRATUIT)
# Créez un compte sur https://mailgun.com et récupérez les identifiants SMTP
MAILGUN_DOMAIN=sandbox123.mailgun.org
MAILGUN_SMTP_USER=postmaster@sandbox123.mailgun.org
MAILGUN_SMTP_PASSWORD=votre-password-mailgun

# 🥉 Option 3: Gmail (500 emails/jour - peut avoir des timeouts sur Render)
# Activez 2FA et créez un mot de passe d'application
GMAIL_USER=votre-email@gmail.com
GMAIL_APP_PASSWORD=votre-mot-de-passe-app

# Option 4: SMTP Générique (si aucune des options ci-dessus)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=votre-username
EMAIL_PASSWORD=votre-password
EMAIL_SECURE=false

# Email From (obligatoire pour toutes les options)
EMAIL_FROM=noreply@harvests.sn

# Configuration EmailJS (FALLBACK OPTIONNEL - 200 emails/mois GRATUIT)
# EmailJS est utilisé comme solution de secours si Nodemailer échoue
# EmailJS n'est PAS obligatoire - c'est juste un fallback optionnel
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Configuration Cloudinary (Upload d'images)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Configuration Stripe (Paiements)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Configuration PayPal (Paiements)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox
PAYPAL_DEFAULT_CURRENCY=EUR
PAYPAL_SUPPORTED_CURRENCIES=EUR,USD
PAYPAL_RETURN_URL=https://votre-frontend/payments/paypal/success
PAYPAL_CANCEL_URL=https://votre-frontend/payments/paypal/cancel
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_FEE_PERCENT=3.4
PAYPAL_FIXED_FEE=0.30
PAYPAL_EXCHANGE_RATES={"XAF->EUR":0.0016}
PAYPAL_DEFAULT_EXCHANGE_RATE=0.0016

# Configuration des frais de livraison
DELIVERY_FEE_PICKUP_LOCAL=0
DELIVERY_FEE_STANDARD_LOCAL=2000
DELIVERY_FEE_EXPRESS_LOCAL=5000
DELIVERY_FEE_SAME_DAY_LOCAL=7000
DELIVERY_FEE_SCHEDULED_LOCAL=3000
DELIVERY_FEE_INTERCITY_BASE=4000
DELIVERY_FEE_PER_KM=0
DELIVERY_FEE_INTERNATIONAL_BASE=8000
DELIVERY_FEE_INTERCITY_STANDARD=4000
DELIVERY_FEE_INTERCITY_EXPRESS=6000
DELIVERY_FEE_INTERCITY_SAME_DAY=8000
DELIVERY_FEE_INTERCITY_SCHEDULED=5000
DELIVERY_FEE_INTERNATIONAL_STANDARD=8000
DELIVERY_FEE_INTERNATIONAL_EXPRESS=10000
DELIVERY_FEE_INTERNATIONAL_SAME_DAY=12000
DELIVERY_FEE_INTERNATIONAL_SCHEDULED=9000

# Configuration Redis (Cache et sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# Configuration des services de SMS
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret

# Configuration des services de géolocalisation
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Configuration des logs
LOG_LEVEL=info
LOG_FILE=logs/harvests.log

# Configuration de sécurité
ENCRYPTION_KEY=your-32-character-encryption-key
BCRYPT_ROUNDS=12

# Configuration des taux de change
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# URLs du frontend
FRONTEND_URL=https://harvests-khaki.vercel.app
ADMIN_URL=http://localhost:3001

# Configuration des webhooks
WEBHOOK_SECRET=your_webhook_secret_key

# Configuration du premier administrateur (Production)
# Ces variables sont utilisées pour créer automatiquement le premier admin en production
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Harvests
ADMIN_EMAIL=admin@harvests.sn
ADMIN_PASSWORD=Admin@Harvests2024!

# Configuration des notifications push
FCM_SERVER_KEY=your_firebase_server_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Configuration des services tiers
WEATHER_API_KEY=your_weather_api_key
CURRENCY_API_KEY=your_currency_api_key

# Configuration des avis (pour les tests)
ALLOW_REVIEWS_WITHOUT_ORDER=true
