# Configuration de l'API Backend
# URL de développement
VITE_API_URL=http://localhost:8000/api/v1
# URL de production (décommentez pour la production)
# VITE_API_URL=https://harvests.onrender.com/api/v1

# Configuration de l'application
VITE_APP_NAME=Harvests
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="L'Amazon des produits agricoles africains"

# Configuration de développement
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# Configuration des services externes
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# Configuration analytics (optionnel)
VITE_GA_TRACKING_ID=
VITE_HOTJAR_ID=

# Configuration des fonctionnalités
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_ANALYTICS=false

# Configuration régionale
VITE_DEFAULT_COUNTRY=CM
VITE_DEFAULT_CURRENCY=XAF
VITE_DEFAULT_LANGUAGE=fr

# Configuration de sécurité
VITE_ENABLE_HTTPS=false
VITE_ENABLE_CSP=true
